      "name": "DevSecOps 规则集",
      "description": "适用于 CI/CD 流水线的安全规则",
      "enabled_rules": [
        "code_security.hardcoded_secrets",
        "code_security.backdoor_code",
        "injection_security.command_injection",
        "injection_security.sql_injection",
