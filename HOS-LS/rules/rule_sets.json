    "owasp_top10": {
      "name": "OWASP Top 10 规则集",
      "description": "基于 OWASP Top 10 2021 的安全规则",
      "enabled_rules": [
        "injection_security.command_injection",
        "injection_security.sql_injection",
        "injection_security.xss",
        "injection_security.path_traversal",
