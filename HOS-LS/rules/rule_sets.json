        "ai_security.adversarial_examples",
        "code_security.hardcoded_secrets",
        "code_security.hardcoded_secrets_encoded",
        "code_security.hardcoded_secrets_cloud",
        "code_security.ai_model_loading",
        "code_security.ai_input_validation",
        "code_security.backdoor_code",
        "code_security.command_injection_ai_generated",
        "code_security.command_injection_shell_true_enhanced",
        "injection_security.command_injection",
        "injection_security.sql_injection",
