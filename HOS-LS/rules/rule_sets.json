        "cloud_security.hardcoded_cloud_credentials",
        "cloud_security.overly_permissive_iam",
        "cloud_security.public_access",
        "cloud_security.unencrypted_storage",
        "code_security.hardcoded_secrets",
        "code_security.backdoor_code",
        "network_security.public_ports",
        "network_security.hardcoded_ip",
        "permission_security.ssh_key_permissions",
