  },
  "project_types": {
    "openclaw": {
      "name": "OpenClaw 项目",
      "rule_set": "openclaw",
      "detect_patterns": [
        "openclaw",
        "skill",
        "gateway"
      ]
    },
    "cursor": {
      "name": "Cursor 生成项目",
      "rule_set": "cursor",
      "detect_patterns": [
        "\\.cursor/",
        "cursor",
        "\\.cursorrules"
      ]
    },
    "trae": {
      "name": "Trae 生成项目",
      "rule_set": "trae",
      "detect_patterns": [
        "\\.trae/",
        "trae",
        "\\.trae_rules"
      ]
    },
    "kiro": {
      "name": "Kiro 生成项目",
      "rule_set": "kiro",
      "detect_patterns": [
        "\\.kiro/",
        "kiro",
        "\\.kiro_rules"
      ]
    },
    "container": {
      "name": "容器项目",
      "rule_set": "container_security",
      "detect_patterns": [
        "Dockerfile",
        "docker-compose\\.yml",
        "\\.dockerignore",
        "kubernetes",
        "\\.yaml",
        "\\.yml"
      ]
    },
    "cloud": {
      "name": "云项目",
      "rule_set": "cloud_security",
      "detect_patterns": [
        "terraform",
        "\\.tf$",
        "cloudformation",
        "template\\.yaml",
        "aws_",
        "azure_",
        "gcp_"
      ]
    },
    "ai_model": {
      "name": "AI 模型项目",
      "rule_set": "ai_security",
      "detect_patterns": [
        "\\.pt$",
        "\\.pth$",
        "\\.onnx$",
        "\\.h5$",
        "\\.pb$",
        "model",
        "tensorflow",
        "pytorch",
        "transformers",
        "huggingface"
      ]
    },
    "ai_web": {
      "name": "AI Web 应用",
      "rule_set": "high_security",
      "detect_patterns": [
        "flask",
        "fastapi",
        "django",
        "streamlit",
        "gradio"
      ]
    },
    "web_app": {
      "name": "Web 应用项目",
      "rule_set": "web_security",
      "detect_patterns": [
        "flask",
        "django",
        "express",
        "react",
        "vue",
        "angular"
      ]
    },
    "privacy_sensitive": {
      "name": "隐私敏感项目",
      "rule_set": "privacy_protection",
      "detect_patterns": [
        "gdpr",
        "privacy",
        "pii",
        "personal_data",
        "user_data"
      ]
    },
    "devsecops": {
      "name": "DevSecOps 项目",
      "rule_set": "devsecops",
      "detect_patterns": [
        "\\.github/workflows",
        "\\.gitlab-ci\\.yml",
        "Jenkinsfile",
        "ci/",
        "cd/"
      ]
    }
  },
  "detection_config": {
    "max_file_size": 10485760,
    "timeout_per_file": 30,
    "parallel_files": 10,
    "confidence_threshold": 0.5,
    "severity_weights": {
      "HIGH": 3,
      "MEDIUM": 2,
      "LOW": 1
    },
    "file_extensions": {
      "python": [".py", ".pyw"],
      "javascript": [".js", ".jsx", ".ts", ".tsx"],
      "config": [".json", ".yaml", ".yml", ".toml", ".ini", ".env"],
      "shell": [".sh", ".bash", ".zsh"],
      "docker": ["Dockerfile", ".dockerfile"],
      "kubernetes": [".yaml", ".yml"],
      "terraform": [".tf", ".tfvars"]
    }
  }
}
